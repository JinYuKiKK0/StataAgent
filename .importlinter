[importlinter]
root_package = stata_agent

[importlinter:contract:top_level_layers]
name = StataAgent top-level package layering
type = layers
layers =
    stata_agent.interfaces
    stata_agent.workflow
    stata_agent.providers
    stata_agent.domains

[importlinter:contract:new_packages_avoid_legacy_shims]
name = New packages must avoid legacy shim modules
type = forbidden
source_modules =
    stata_agent.interfaces
    stata_agent.workflow
    stata_agent.providers
forbidden_modules =
    stata_agent.application
    stata_agent.adapters
    stata_agent.cli
    stata_agent.config
    stata_agent.logging
    stata_agent.workflows
